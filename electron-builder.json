{
  "appId": "com.epubmanager.app",
  "productName": "EPUB Manager",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "assets/**/*",
    "data/**/*",
    "node_modules/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ]
  },
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ]
}
